# mv "$HOME/Library/Application Support/com.mitchellh.ghostty/config.ghostty" ~/projects/senaev-laptop-settings/ghostty/config.ghostty
# ln -s ~/projects/senaev-laptop-settings/ghostty/config.ghostty "$HOME/Library/Application Support/com.mitchellh.ghostty/config.ghostty"
font-family = "Fira Code"
keybind = global:cmd+grave_accent=toggle_quick_terminal
# number of bytes, default is 10000000
scrollback-limit = 100000000
